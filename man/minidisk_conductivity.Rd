)
meta <- tibble(
  sample  = c("A", "B"),
  texture = c("Sandy Loam", "Loam"),
  suction = 2
)

multi |>
  group_by(sample) |>
  infiltration_cumulative(time = time, volume = volume) |>
  fit_infiltration(.infiltration, .sqrt_time) |>
  left_join(meta, by = "sample") |>
  minidisk_conductivity(texture = texture, suction = suction)

